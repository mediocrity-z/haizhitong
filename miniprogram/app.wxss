/* 全局样式 - 狮城助手 */
page {
  --primary: #1a3a5c;
  --primary-light: #2d5f8a;
  --primary-dark: #0f2440;
  --accent: #e8913a;
  --success: #2ecc71;
  --danger: #e74c3c;
  --bg: #f5f7fa;
  --card-bg: #ffffff;
  --text: #2c3e50;
  --text-secondary: #7f8c8d;
  --border: #e0e6ed;
  --shadow: 0 2px 12px rgba(0, 0, 0, 0.08);

  background-color: var(--bg);
  font-family:
    -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  display: block;
  width: 100%;
  box-shadow: 0 4px 12px rgba(26, 58, 92, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-primary[disabled] {
  background: #bdc3c7;
  box-shadow: none;
  color: #95a5a6;
}

/* 卡片 */
.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-label .required {
  color: var(--danger);
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 1px solid var(--border);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary-light);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 1px solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 88rpx;
  border: 1px solid var(--border);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.form-radio-group {
  display: flex;
  gap: 32rpx;
}

.form-radio {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(180deg, var(--primary), var(--primary-light));
  color: #fff;
  padding: 32rpx 32rpx 48rpx;
  border-radius: 0 0 32rpx 32rpx;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
}

.page-subtitle {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: var(--text-secondary);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

/* 加载 */
.loading-more {
  text-align: center;
  padding: 24rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}
