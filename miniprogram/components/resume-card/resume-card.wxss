.resume-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.resume-card.compact {
  padding: 20rpx;
  box-shadow: none;
  border: 1px solid #e0e6ed;
}

.resume-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #1a3a5c;
  margin-bottom: 24rpx;
}

.resume-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a3a5c;
}

.resume-badge {
  background: linear-gradient(135deg, #e8913a, #f0a55a);
  color: #fff;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.resume-section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a3a5c;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #e8913a;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  margin-bottom: 16rpx;
}

.info-item:only-child {
  width: 100%;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #95a5a6;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: #2c3e50;
}

.timeline {
  display: flex;
  padding-left: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.timeline::before {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 16rpx;
  bottom: -20rpx;
  width: 2rpx;
  background: #e0e6ed;
}

.timeline:last-child::before {
  display: none;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1a3a5c;
  flex-shrink: 0;
  margin-top: 8rpx;
  margin-right: 20rpx;
  position: relative;
  z-index: 1;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2c3e50;
}

.timeline-period {
  font-size: 24rpx;
  color: #95a5a6;
  margin: 4rpx 0;
}

.timeline-desc {
  font-size: 26rpx;
  color: #7f8c8d;
  line-height: 1.5;
}

.skills-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-tag {
  background: rgba(26, 58, 92, 0.06);
  color: #1a3a5c;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  border: 1px solid rgba(26, 58, 92, 0.12);
}
