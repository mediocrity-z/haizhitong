.profile-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* 登录引导 */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx 60rpx;
}

.login-avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.login-icon {
  font-size: 80rpx;
  color: #fff;
}

.login-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}

.login-section .btn-primary {
  width: 400rpx;
}

/* 用户头部 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}

.avatar-placeholder {
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.profile-info {
  margin-left: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.role-tag {
  font-size: 20rpx;
  color: #fff;
  background: var(--accent);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

/* AI 次数卡片 */
.quota-card {
  margin: -20rpx 20rpx 24rpx;
  position: relative;
  z-index: 1;
}

.quota-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.quota-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quota-bar {
  flex: 1;
  height: 16rpx;
  background: #e8ecf0;
  border-radius: 8rpx;
  overflow: hidden;
}

.quota-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--success), #27ae60);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.quota-fill.low {
  background: linear-gradient(90deg, var(--accent), var(--danger));
}

.quota-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

/* 历史列表 */
.section {
  padding: 0 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
}

.history-main {
  flex: 1;
  overflow: hidden;
}

.history-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  font-size: 22rpx;
  color: #b0b8c0;
  margin-top: 4rpx;
}

.history-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin: 0 16rpx;
}

.history-status.done {
  background: #e8f5e9;
  color: #2e7d32;
}

.history-status.pending {
  background: #fff3e0;
  color: #e65100;
}

.history-arrow {
  font-size: 36rpx;
  color: #c0c8d0;
  flex-shrink: 0;
}

/* 空状态 */
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 退出 */
.logout-area {
  padding: 48rpx 60rpx;
}

.logout-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #fff;
  color: var(--text-secondary);
  border: 1px solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 0;
}
