.visa-page {
  min-height: 100vh;
  background: #f5f7fa;
}

.search-section {
  margin: 24rpx;
}

.search-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.country-input {
  flex: 1;
  height: 80rpx;
  border: 1px solid #e0e6ed;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #fff;
}

.search-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #1a3a5c, #2d5f8a);
  color: #fff;
  border: none;
  text-align: center;
  padding: 0;
}

.search-btn[disabled] {
  background: #e0e6ed;
  color: #95a5a6;
}

.quick-countries {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.country-tag {
  background: rgba(26, 58, 92, 0.06);
  color: #1a3a5c;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  border: 1px solid rgba(26, 58, 92, 0.12);
}

.country-tag:active {
  background: #1a3a5c;
  color: #fff;
}

/* 加载 */
.loading-card {
  text-align: center;
  padding: 60rpx 40rpx;
  margin: 24rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e6ed;
  border-top-color: #1a3a5c;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #2c3e50;
}

/* 结果 */
.result-card {
  margin: 24rpx;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #1a3a5c;
  margin-bottom: 24rpx;
}

.result-country {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a3a5c;
}

.result-time {
  font-size: 22rpx;
  color: #bdc3c7;
}

.result-body {
  font-size: 28rpx;
  line-height: 1.8;
  color: #2c3e50;
}

.result-tip {
  margin-top: 24rpx;
  padding: 16rpx;
  background: #fff3e0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #e8913a;
  text-align: center;
}

/* 历史 */
.history-section {
  margin: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-item {
  background: #fff;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #1a3a5c;
  border: 1px solid #e0e6ed;
}

.history-item:active {
  background: #1a3a5c;
  color: #fff;
}
