.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f7fa;
}

/* 顶部标题栏 */
.chat-header {
  background: linear-gradient(135deg, #1a3a5c, #2d5f8a);
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-title {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.header-brand {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.header-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2ecc71;
}

.status-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 消息区域 */
.chat-messages {
  flex: 1;
  overflow: hidden;
}

.messages-container {
  padding: 16rpx 0;
  padding-bottom: 32rpx;
}

/* 欢迎卡片 */
.welcome-card {
  background: #fff;
  margin: 24rpx 32rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
}

.welcome-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a3a5c;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #7f8c8d;
  margin-bottom: 24rpx;
}

.welcome-topics {
  text-align: left;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
}

.topic-item {
  font-size: 26rpx;
  color: #2c3e50;
  line-height: 2;
}

.welcome-footer {
  font-size: 24rpx;
  color: #bdc3c7;
}

/* 报名引导卡片 */
.register-guide-card {
  background: linear-gradient(135deg, #fff9f0, #fff5e6);
  margin: 24rpx 32rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  border: 2rpx solid #e8913a;
}

.guide-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e8913a;
  margin-bottom: 12rpx;
}

.guide-desc {
  font-size: 26rpx;
  color: #7f8c8d;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.guide-actions {
  display: flex;
  gap: 16rpx;
}

.guide-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  border: 1px solid #e0e6ed;
  background: #fff;
  color: #2c3e50;
}

.guide-btn.primary {
  background: linear-gradient(135deg, #e8913a, #f0a55a);
  color: #fff;
  border: none;
}

/* 打字动画 */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 32rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #bdc3c7;
  animation: typing 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) {
  animation-delay: 0s;
}
.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}
.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%,
  80%,
  100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 底部输入区 */
.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1px solid #f0f0f0;
  gap: 16rpx;
}

.input-wrapper {
  flex: 1;
  background: #f5f7fa;
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}

.chat-input {
  width: 100%;
  height: 100%;
  font-size: 28rpx;
  color: #2c3e50;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #e0e6ed;
  color: #95a5a6;
  text-align: center;
  border: none;
  padding: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #1a3a5c, #2d5f8a);
  color: #fff;
}

.send-btn[disabled] {
  opacity: 0.8;
}
