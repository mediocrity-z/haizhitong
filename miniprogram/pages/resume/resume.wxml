<view class="resume-page">
  <view class="page-header">
    <view class="page-title">我的简历</view>
    <view class="page-subtitle" wx:if="{{resumeStatusText}}">状态：{{resumeStatusText}}</view>
  </view>

  <view class="empty-state" wx:if="{{!hasRegistration}}">
    <view class="empty-icon">📄</view>
    <view class="empty-title">暂无简历</view>
    <view class="empty-desc">您还未填写个人信息</view>
    <button class="btn-primary" style="width: 300rpx; margin-top: 32rpx;" bindtap="goRegister">去填写</button>
  </view>

  <view class="card" wx:if="{{hasRegistration && resumeHtml}}">
    <view class="success-icon">✅</view>
    <view class="success-title">简历已生成</view>
    <view class="success-desc">点击下方按钮查看或分享</view>
    <button class="btn-primary" bindtap="downloadResume">下载简历</button>
    <button class="btn-outline" style="margin-top: 20rpx;" bindtap="enhanceResume" disabled="{{enhancing}}">{{enhancing ? 'AI 优化中...' : 'AI 优化工作经历'}}</button>
    <button class="btn-outline" style="margin-top: 20rpx;" bindtap="regenerateResume">重新填写</button>
  </view>

  <view class="card" wx:if="{{hasRegistration && !resumeHtml}}">
    <view class="p-text">暂无可预览的简历文件</view>
    <button class="btn-primary" style="margin-top: 24rpx;" bindtap="regenerateResume">重新生成</button>
  </view>
</view>
