.resume-page {
  min-height: 100vh;
  background: #f5f7fa;
}

.success-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.success-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
  text-align: center;
  margin-bottom: 8rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #95a5a6;
  text-align: center;
  margin-bottom: 36rpx;
}

.btn-outline {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  background: #fff;
  color: #1a3a5c;
  border: 1px solid #1a3a5c;
  padding: 0;
}

.btn-outline::after {
  border: none;
}

.back-link {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 12rpx;
  display: inline-block;
}
